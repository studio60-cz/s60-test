{
  "name": "s60-test",
  "version": "1.0.0",
  "description": "S60 centralized test infrastructure — E2E, API, integration, security",
  "private": true,
  "scripts": {
    "test:smoke": "bash suites/smoke/run-smoke.sh",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:debug": "npx playwright test --debug",
    "report": "allure generate /tmp/allure-results -o /tmp/allure-report --clean && allure open /tmp/allure-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "allure-playwright": "^3.6.0"
  }
}
